{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "disabledMcpjsonServers": ["postgres", "pulumi", "aws"],
  "permissions": {
    "allow": [
      "Bash(bun *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch)",
      "Bash(git branch --show-current*)",
      "Bash(git branch --list*)",
      "Bash(git branch -a*)",
      "Bash(git branch -r*)",
      "Bash(git branch -v*)",
      "Bash(git branch --contains*)",
      "Bash(git rev-parse*)",
      "Bash(git remote -v*)",
      "Bash(git remote show*)",
      "Bash(echo *)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(git checkout -- *)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(gh pr create*)",
      "Bash(gh pr view*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr status*)",
      "Bash(docker compose *)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(*)",
      "Write(*)",
      "WebFetch(domain:bun.com)",
      "WebFetch(domain:effect.website)",
      "WebFetch(domain:orm.drizzle.team)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.npmjs.com)"
    ],
    "ask": [
      "Bash(git checkout *)",
      "Bash(git branch -d*)",
      "Bash(git branch -D*)",
      "Bash(git branch -m*)",
      "Bash(git branch -M*)",
      "Bash(git branch -f*)",
      "Bash(git branch --delete*)",
      "Bash(git branch --move*)",
      "Bash(git branch --force*)",
      "Bash(git rebase*)",
      "Bash(git reset *)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(pnpm *)"
    ]
  }
}
