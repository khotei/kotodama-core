{
  "name": "kotodama",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "core",
    "database",
    "platform",
    "infra",
    "infra/presets"
  ],
  "catalogs": {
    "runtime": {
      "bun-types": "^1.3.0",
      "@types/node": "^22.10.0",
      "typescript": "^5.7.0",
      "@effect/language-service": "^0.85.1"
    },
    "otel": {
      "@opentelemetry/api": "^1.9.1",
      "@opentelemetry/api-logs": "^0.217.0",
      "@opentelemetry/resources": "^2.7.1",
      "@opentelemetry/sdk-logs": "^0.217.0",
      "@opentelemetry/sdk-metrics": "^2.7.1",
      "@opentelemetry/sdk-trace-base": "^2.7.1",
      "@opentelemetry/sdk-trace-node": "^2.7.1",
      "@opentelemetry/semantic-conventions": "^1.40.0",
      "@opentelemetry/exporter-trace-otlp-http": "^0.217.0"
    },
    "effect": {
      "effect": "4.0.0-beta.78",
      "@effect/platform-bun": "4.0.0-beta.78",
      "@effect/sql-pg": "4.0.0-beta.78",
      "@effect/ai-openai": "4.0.0-beta.78",
      "@effect/opentelemetry": "4.0.0-beta.78",
      "@effect/vitest": "4.0.0-beta.78",
      "vitest": "^3.2.0"
    },
    "db": {
      "drizzle-orm": "1.0.0-rc.3",
      "drizzle-kit": "1.0.0-rc.3"
    },
    "test": {
      "@faker-js/faker": "^9.4.0",
      "@testcontainers/localstack": "12.0.2",
      "@testcontainers/postgresql": "12.0.2",
      "testcontainers": "12.0.2"
    },
    "aws": {
      "@aws-sdk/client-sqs": "^3.700.0",
      "@aws-sdk/client-s3": "^3.700.0"
    },
    "ai": {
      "openai": "^4.77.0"
    },
    "types": {
      "type-fest": "^5.7.0",
      "@types/aws-lambda": "^8.10.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@effect/language-service": "catalog:runtime",
    "@effect/vitest": "catalog:effect",
    "bun-types": "catalog:runtime",
    "husky": "^9.1.7",
    "typescript": "catalog:runtime",
    "vitest": "catalog:effect"
  },
  "scripts": {
    "prepare": "husky",
    "bootstrap": "bun install",
    "format": "biome format --write --config-path infra/presets/src/biome.base.json .",
    "lint": "biome lint --config-path infra/presets/src/biome.base.json .",
    "tsc": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "check": "bun run lint && bun run tsc",
    "vendor:effect:add": "git subtree add --prefix=repos/effect-smol https://github.com/Effect-TS/effect-smol.git main --squash",
    "vendor:effect:update": "git subtree pull --prefix=repos/effect-smol https://github.com/Effect-TS/effect-smol.git main --squash",
    "vendor:drizzle:add": "git subtree add --prefix=repos/drizzle https://github.com/drizzle-team/drizzle-orm.git v1.0.0-rc.3 --squash",
    "vendor:drizzle:update": "git subtree pull --prefix=repos/drizzle https://github.com/drizzle-team/drizzle-orm.git v1.0.0-rc.3 --squash"
  }
}
