{
  "name": "@kotodama/database",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing.ts",
    "./factories": "./src/factories/index.ts"
  },
  "scripts": {
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:push": "bun --bun drizzle-kit push",
    "db:reset": "echo 'TODO(db:reset): drop + recreate + migrate \u2014 wired with the deploy runner'",
    "db:seed": "bun run src/seed.ts",
    "test": "bun --bun vitest run",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:effect",
    "@effect/sql-pg": "catalog:effect",
    "@kotodama/config": "workspace:*",
    "drizzle-kit": "catalog:db",
    "drizzle-orm": "catalog:db",
    "effect": "catalog:effect",
    "type-fest": "catalog:types"
  },
  "devDependencies": {
    "@faker-js/faker": "catalog:test",
    "@testcontainers/postgresql": "catalog:test",
    "testcontainers": "catalog:test"
  }
}
