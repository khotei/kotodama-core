# LexiAI environment — copy to .env (git-ignored) and fill in.
# Every key here is consumed by core/config AppConfig (Tech spec §2.5).
# Defaults below target the local Docker Compose infra (Postgres + LocalStack).

# Postgres connection string (local dev DB from infra/local/docker-compose.yml).
# Tests don't use this — they spin an ephemeral Testcontainers Postgres
# (@lexiai/database/testing), so there is no .env.test.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lexiai_dev

# S3 bucket for generated images. Against LocalStack S3 (endpoint http://localhost:4566)
IMAGES_BUCKET=lexiai-images

# SQS queue URL for word-generation jobs. Against LocalStack SQS (endpoint http://localhost:4566)
JOBS_QUEUE_URL=http://localhost:4566/000000000000/lexiai-jobs

# OpenAI API key (text + image generation)
OPENAI_API_KEY=sk-local-placeholder

# AWS region (LocalStack accepts any; us-east-1 is the conventional default)
AWS_REGION=us-east-1

# LocalStack endpoint for AWS SDKs (SQS + S3) in local dev
AWS_ENDPOINT_URL=http://localhost:4566

# S3 credentials for Bun.S3Client (@lexiai/storage). LocalStack accepts any value; in prod the
# Lambda execution role injects these (plus AWS_SESSION_TOKEN) into the environment instead.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# HTTP port for apps/api (keep in sync with VITE_API_BASE_URL's port below)
PORT=3000

# How many word builds the worker runs at once. Keep at 1 on a low OpenAI usage tier
# (the gpt-image rate limit ≈ 5 images/min — concurrent builds collide on a 429); raise
# it once a higher tier lifts the limit. No redeploy needed — just change this var.
WORKER_CONCURRENCY=1

# --- Observability ---
# OTLP/HTTP trace endpoint. Read directly by @lexiai/observability (TracingLive),
# NOT by AppConfig — OTEL_EXPORTER_OTLP_ENDPOINT is the OpenTelemetry-standard var.
# Unset locally: defaults to the Jaeger container (UI at http://localhost:16686).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Frontend only (apps/web, Vite) ---
# Base URL the SPA calls for the API
VITE_API_BASE_URL=http://localhost:3000
