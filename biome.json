{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!repos", "!**/dist", "!**/migrations"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error"
      },
      "suspicious": {
        "noExplicitAny": "error"
      },
      "style": {
        "useImportType": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": ["**/repos/**"],
                "message": "Do not import from repos/ \u2014 it is vendored, read-only reference material. Import the published package (effect, @effect/*) instead."
              }
            ]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@lexiai/use-cases",
                      "@lexiai/use-cases-*",
                      "@lexiai/core-*",
                      "@lexiai/repositories-*",
                      "@lexiai/apps-*",
                      "@lexiai/database",
                      "@lexiai/database/factories"
                    ],
                    "message": "Layer violation: packages/* are leaves and must not import use-cases, core, repositories, database, or apps. See CLAUDE.md dependency hierarchy."
                  },
                  {
                    "group": ["**/repos/**"],
                    "message": "Do not import from repos/ \u2014 it is vendored, read-only reference material. Import the published package (effect, @effect/*) instead."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["database/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@lexiai/use-cases",
                      "@lexiai/use-cases-*",
                      "@lexiai/core-*",
                      "@lexiai/repositories-*",
                      "@lexiai/apps-*"
                    ],
                    "message": "Layer violation: database/ may only import @lexiai/* packages, never use-cases, core, repositories, or apps."
                  },
                  {
                    "group": ["**/repos/**"],
                    "message": "Do not import from repos/ \u2014 it is vendored, read-only reference material. Import the published package (effect, @effect/*) instead."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["repositories/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@lexiai/use-cases",
                      "@lexiai/use-cases-*",
                      "@lexiai/core-*",
                      "@lexiai/apps-*"
                    ],
                    "message": "Layer violation: repositories/* may depend on database and packages only, never use-cases, core, or apps."
                  },
                  {
                    "group": ["**/repos/**"],
                    "message": "Do not import from repos/ \u2014 it is vendored, read-only reference material. Import the published package (effect, @effect/*) instead."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["core/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@lexiai/use-cases", "@lexiai/use-cases-*", "@lexiai/apps-*"],
                    "message": "Layer violation: core/* must not import use-cases or apps."
                  },
                  {
                    "group": ["**/repos/**"],
                    "message": "Do not import from repos/ \u2014 it is vendored, read-only reference material. Import the published package (effect, @effect/*) instead."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["use-cases/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@lexiai/apps-*"],
                    "message": "Layer violation: use-cases/ is the top tier below apps \u2014 it composes core, repositories, database, and packages, but must not import apps."
                  },
                  {
                    "group": ["**/repos/**"],
                    "message": "Do not import from repos/ \u2014 it is vendored, read-only reference material. Import the published package (effect, @effect/*) instead."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
