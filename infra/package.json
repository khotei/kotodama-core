{
  "name": "@lexiai/infra",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "local:up": "docker compose -f local/docker-compose.yml up -d --wait && bun run --filter '@lexiai/database' db:migrate && bun run local:provision",
    "local:down": "docker compose -f local/docker-compose.yml down",
    "local:clean": "docker compose -f local/docker-compose.yml down -v",
    "local:logs": "docker compose -f local/docker-compose.yml logs -f",
    "local:provision": "bun run src/local-provision.ts",
    "local:smoke": "bun run src/local-smoke.ts",
    "test": "bun --bun vitest run",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:aws",
    "@aws-sdk/client-sqs": "catalog:aws",
    "@effect/platform-bun": "catalog:effect",
    "@lexiai/config": "workspace:*",
    "@lexiai/queue": "workspace:*",
    "@lexiai/storage": "workspace:*",
    "effect": "catalog:effect"
  }
}
