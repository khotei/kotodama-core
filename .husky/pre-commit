#!/usr/bin/env sh
# Pre-commit gate (F-PLAT-001/T04, F-PLAT-002/T03): Biome + typecheck.
# Fast-fail; tests run in CI only (T12), never here. Bypass with --no-verify.

# Lint + format check on staged files only.
bun biome check --config-path packages/tooling/biome.base.json --staged --no-errors-on-unmatched || exit 1

# Typecheck every workspace via Bun filters (`bun run tsc` =
# `bun run --filter '*' typecheck`, each package's `tsc --noEmit`). Replaces the
# old `tsc -b`, which relied on the root solution `references` removed in
# F-PLAT-002/T02 — with no references, `tsc -b` typechecked nothing. Packages
# resolve each other's source via workspace:* + bundler resolution, so no
# project references are needed for correctness.
bun run tsc || exit 1
